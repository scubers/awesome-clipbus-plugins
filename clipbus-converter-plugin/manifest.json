{
  "schemaVersion": 4,
  "plugin": {
    "id": "plugin.converter",
    "title": "Converter",
    "version": "0.1.0"
  },
  "install": {
    "runtime": "node",
    "entry": "scripts/install.mjs"
  },
  "runtime": {
    "nodeEntry": "dist/plugin.cjs",
    "uiRoot": "dist/ui"
  },
  "permissions": ["setAttachment"],
  "detectors": [
    {
      "id": "timestamp-detector",
      "title": "Unix Timestamp Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.converter.timestamp"]
    },
    {
      "id": "radix-detector",
      "title": "Radix Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.converter.radix"]
    },
    {
      "id": "duration-detector",
      "title": "Duration Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.converter.duration"]
    },
    {
      "id": "temperature-detector",
      "title": "Temperature Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.converter.temperature"]
    },
    {
      "id": "filesize-detector",
      "title": "Data Size Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.converter.filesize"]
    },
    {
      "id": "chmod-detector",
      "title": "File Permission Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.converter.chmod"]
    }
  ],
  "attachmentRenderers": [
    {
      "id": "timestamp-renderer",
      "title": "Unix Timestamp Converter",
      "attachmentType": "plugin.converter.timestamp",
      "height": { "min": 140, "max": 460 },
      "uiEntry": "renderers/timestamp-renderer/index.html"
    },
    {
      "id": "radix-renderer",
      "title": "Radix Converter",
      "attachmentType": "plugin.converter.radix",
      "height": { "min": 120, "max": 300 },
      "uiEntry": "renderers/radix-renderer/index.html"
    },
    {
      "id": "duration",
      "title": "Duration",
      "attachmentType": "plugin.converter.duration",
      "height": { "min": 140, "max": 300 },
      "uiEntry": "renderers/duration/index.html"
    },
    {
      "id": "temperature",
      "title": "Temperature",
      "attachmentType": "plugin.converter.temperature",
      "height": { "min": 140, "max": 300 },
      "uiEntry": "renderers/temperature/index.html"
    },
    {
      "id": "filesize-renderer",
      "title": "Data Size",
      "attachmentType": "plugin.converter.filesize",
      "height": { "min": 180, "max": 420 },
      "uiEntry": "renderers/filesize-renderer/index.html"
    },
    {
      "id": "chmod-renderer",
      "title": "File Permissions",
      "attachmentType": "plugin.converter.chmod",
      "height": { "min": 180, "max": 380 },
      "uiEntry": "renderers/chmod-renderer/index.html"
    }
  ],
  "actions": [
    {
      "id": "uppercase",
      "title": "Uppercase",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["uppercase", "upper", "case"]
    },
    {
      "id": "lowercase",
      "title": "Lowercase",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["lowercase", "lower", "case"]
    },
    {
      "id": "camelCase",
      "title": "camelCase",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["camel", "case", "naming"]
    },
    {
      "id": "pascalCase",
      "title": "PascalCase",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["pascal", "case", "naming"]
    },
    {
      "id": "snakeCase",
      "title": "snake_case",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["snake", "case", "naming"]
    },
    {
      "id": "kebabCase",
      "title": "kebab-case",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["kebab", "case", "naming"]
    },
    {
      "id": "constantCase",
      "title": "CONSTANT_CASE",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["constant", "case", "naming"]
    },
    {
      "id": "titleCase",
      "title": "Title Case",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["title", "case", "naming"]
    },
    {
      "id": "sentenceCase",
      "title": "Sentence case",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["sentence", "case", "naming"]
    },
    {
      "id": "dotCase",
      "title": "dot.case",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["dot", "case", "naming"]
    }
  ]
}
