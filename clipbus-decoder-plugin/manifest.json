{
  "schemaVersion": 3,
  "plugin": {
    "id": "plugin.decoder",
    "title": "Decoder",
    "version": "0.1.0"
  },
  "install": {
    "runtime": "node",
    "entry": "scripts/install.mjs"
  },
  "runtime": {
    "nodeEntry": "dist/plugin.cjs",
    "uiRoot": "dist/ui"
  },
  "permissions": ["setAttachment"],
  "detectors": [
    {
      "id": "base64-detector",
      "title": "Base64 Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.decoder.base64"]
    },
    {
      "id": "jwt-detector",
      "title": "JWT Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.decoder.jwt"]
    },
    {
      "id": "data-uri-detector",
      "title": "Data URI Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.decoder.datauri"]
    }
  ],
  "attachmentRenderers": [
    {
      "id": "base64-renderer",
      "title": "Base64 Decode",
      "attachmentType": "plugin.decoder.base64",
      "height": { "min": 120, "max": 320 },
      "uiEntry": "renderers/base64-renderer/index.html"
    },
    {
      "id": "jwt-renderer",
      "title": "JWT Parse",
      "attachmentType": "plugin.decoder.jwt",
      "height": { "min": 140, "max": 440 },
      "uiEntry": "renderers/jwt-renderer/index.html"
    },
    {
      "id": "data-uri",
      "title": "Data URI",
      "attachmentType": "plugin.decoder.datauri",
      "height": { "min": 120, "max": 320 },
      "uiEntry": "renderers/data-uri/index.html"
    }
  ],
  "actions": [
    {
      "id": "url-encode",
      "title": "URL Encode",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["url", "percent", "encode", "escape"]
    },
    {
      "id": "url-decode",
      "title": "URL Decode",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["url", "percent", "decode", "unescape"]
    },
    {
      "id": "html-encode",
      "title": "HTML Encode",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["html", "entity", "encode", "escape"]
    },
    {
      "id": "html-decode",
      "title": "HTML Decode",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["html", "entity", "decode", "unescape"]
    },
    {
      "id": "base64-encode",
      "title": "Base64 Encode",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["base64", "encode"]
    },
    {
      "id": "base64-decode",
      "title": "Base64 Decode",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["base64", "decode"]
    },
    {
      "id": "unicode-escape",
      "title": "Unicode Escape",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["unicode", "escape", "encode"]
    },
    {
      "id": "unicode-unescape",
      "title": "Unicode Unescape",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["unicode", "unescape", "decode"]
    },
    {
      "id": "json-escape",
      "title": "JSON Escape",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["json", "escape", "encode"]
    },
    {
      "id": "json-unescape",
      "title": "JSON Unescape",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["json", "unescape", "decode"]
    }
  ]
}
