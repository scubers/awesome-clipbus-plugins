{
  "schemaVersion": 2,
  "plugin": {
    "id": "plugin.decoder",
    "title": "Decoder",
    "version": "0.1.0"
  },
  "install": {
    "runtime": "node",
    "entry": "scripts/install.mjs"
  },
  "runtime": {
    "nodeEntry": "dist/plugin.cjs",
    "uiRoot": "dist/ui"
  },
  "permissions": ["setAttachment"],
  "detectors": [
    {
      "id": "base64-detector",
      "title": "Base64 Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.decoder.base64"]
    },
    {
      "id": "jwt-detector",
      "title": "JWT Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.decoder.jwt"]
    }
  ],
  "attachmentRenderers": [
    {
      "id": "base64-renderer",
      "title": "Base64 Decode",
      "attachmentType": "plugin.decoder.base64",
      "height": { "min": 120, "max": 320 },
      "uiEntry": "renderers/base64-renderer/index.html"
    },
    {
      "id": "jwt-renderer",
      "title": "JWT Parse",
      "attachmentType": "plugin.decoder.jwt",
      "height": { "min": 140, "max": 440 },
      "uiEntry": "renderers/jwt-renderer/index.html"
    }
  ],
  "actions": [
    {
      "id": "escape-tool",
      "title": "Escape & Encode",
      "supportedItemTypes": ["text"],
      "lifecycle": "draft",
      "uiEntry": "actions/escape-tool/index.html",
      "keywords": ["escape", "encode", "decode", "url", "html", "base64", "unicode", "json"]
    }
  ]
}
