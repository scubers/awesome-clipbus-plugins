{
  "schemaVersion": 2,
  "plugin": {
    "id": "plugin.formatter",
    "title": "Code Formatter",
    "version": "0.1.0"
  },
  "install": {
    "runtime": "node",
    "entry": "scripts/install.mjs"
  },
  "runtime": {
    "nodeEntry": "dist/plugin.cjs",
    "uiRoot": "dist/ui"
  },
  "permissions": ["setAttachment"],
  "detectors": [
    {
      "id": "json-detector",
      "title": "JSON 识别",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.formatter.json"]
    },
    {
      "id": "xml-detector",
      "title": "XML 识别",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.xml.formatted"]
    },
    {
      "id": "sql-detector",
      "title": "SQL 识别",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.sql.formatted"]
    }
  ],
  "attachmentRenderers": [
    {
      "id": "json-renderer",
      "title": "JSON 格式化",
      "attachmentType": "plugin.formatter.json",
      "height": { "min": 160, "max": 480 },
      "uiEntry": "renderers/json-renderer/index.html"
    },
    {
      "id": "xml-renderer",
      "title": "XML 格式化",
      "attachmentType": "plugin.xml.formatted",
      "height": { "min": 140, "max": 480 },
      "uiEntry": "renderers/xml-renderer/index.html"
    },
    {
      "id": "sql-renderer",
      "title": "SQL 格式化",
      "attachmentType": "plugin.sql.formatted",
      "height": { "min": 140, "max": 460 },
      "tint": "#0369A1",
      "uiEntry": "renderers/sql-renderer/index.html"
    }
  ],
  "actions": [
    {
      "id": "json-copy",
      "title": "复制格式化 JSON",
      "supportedItemTypes": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["json", "format", "格式化", "美化", "pretty"]
    },
    {
      "id": "xml-copy",
      "title": "复制格式化 XML",
      "supportedItemTypes": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["xml", "html", "format", "格式化", "copy"]
    },
    {
      "id": "sql-copy",
      "title": "复制格式化 SQL",
      "supportedItemTypes": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["sql", "query", "格式化", "copy"]
    }
  ]
}
