{
  "schemaVersion": 2,
  "plugin": {
    "id": "plugin.inspector",
    "title": "Inspector",
    "version": "0.1.0"
  },
  "install": {
    "runtime": "node",
    "entry": "scripts/install.mjs"
  },
  "runtime": {
    "nodeEntry": "dist/plugin.cjs",
    "uiRoot": "dist/ui"
  },
  "permissions": ["setAttachment"],
  "detectors": [
    {
      "id": "text-stats-detector",
      "title": "Text Stats Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.inspector.text-stats"]
    },
    {
      "id": "diff-detector",
      "title": "Unified Diff Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.inspector.diff"]
    }
  ],
  "attachmentRenderers": [
    {
      "id": "text-stats-renderer",
      "title": "Text Stats",
      "attachmentType": "plugin.inspector.text-stats",
      "height": { "min": 160, "max": 360 },
      "uiEntry": "renderers/text-stats-renderer/index.html"
    },
    {
      "id": "diff-renderer",
      "title": "Diff Viewer",
      "attachmentType": "plugin.inspector.diff",
      "height": { "min": 140, "max": 480 },
      "uiEntry": "renderers/diff-renderer/index.html"
    }
  ],
  "actions": []
}
