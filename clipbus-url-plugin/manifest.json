{
  "schemaVersion": 2,
  "plugin": {
    "id": "plugin.url",
    "title": "URL Inspector",
    "version": "0.1.0"
  },
  "install": {
    "runtime": "node",
    "entry": "scripts/install.mjs"
  },
  "runtime": {
    "nodeEntry": "dist/plugin.cjs",
    "uiRoot": "dist/ui"
  },
  "permissions": ["setAttachment"],
  "detectors": [
    {
      "id": "url-detector",
      "title": "URL Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.url.parsed"]
    }
  ],
  "attachmentRenderers": [
    {
      "id": "url-parsed",
      "title": "URL Parsed",
      "attachmentType": "plugin.url.parsed",
      "height": "auto",
      "uiEntry": "renderers/url-parsed/index.html"
    }
  ],
  "actions": []
}
