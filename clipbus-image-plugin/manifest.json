{
  "schemaVersion": 4,
  "plugin": {
    "id": "plugin.image",
    "title": "Image Tools",
    "version": "0.1.0"
  },
  "install": {
    "runtime": "node",
    "entry": "scripts/install.mjs"
  },
  "runtime": {
    "nodeEntry": "dist/plugin.cjs",
    "uiRoot": "dist/ui"
  },
  "permissions": [],
  "detectors": [],
  "attachmentRenderers": [],
  "actions": [
    {
      "id": "image-edit",
      "title": "Crop & Compress",
      "supportedInputKinds": [
        "image"
      ],
      "lifecycle": "draft",
      "uiEntry": "actions/image-edit/index.html",
      "keywords": [
        "crop",
        "compress",
        "resize",
        "quality",
        "image"
      ]
    }
  ]
}
