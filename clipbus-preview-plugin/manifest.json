{
  "schemaVersion": 2,
  "plugin": {
    "id": "plugin.preview",
    "title": "Preview",
    "version": "0.1.0"
  },
  "install": {
    "runtime": "node",
    "entry": "scripts/install.mjs"
  },
  "runtime": {
    "nodeEntry": "dist/plugin.cjs",
    "uiRoot": "dist/ui"
  },
  "permissions": ["setAttachment"],
  "detectors": [
    {
      "id": "color-detector",
      "title": "Color Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.preview.color"]
    },
    {
      "id": "markdown-detector",
      "title": "Markdown Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.preview.markdown"]
    },
    {
      "id": "gradient-detector",
      "title": "Gradient Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.preview.gradient"]
    },
    {
      "id": "qr-detector",
      "title": "QR Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.preview.qr"]
    }
  ],
  "attachmentRenderers": [
    {
      "id": "color-swatch",
      "title": "Color Swatch",
      "attachmentType": "plugin.preview.color",
      "height": 260,
      "uiEntry": "renderers/color-swatch/index.html"
    },
    {
      "id": "markdown-renderer",
      "title": "Markdown Preview",
      "attachmentType": "plugin.preview.markdown",
      "height": { "min": 120, "max": 480 },
      "uiEntry": "renderers/markdown-renderer/index.html"
    },
    {
      "id": "gradient-swatch",
      "title": "Gradient",
      "attachmentType": "plugin.preview.gradient",
      "height": 260,
      "uiEntry": "renderers/gradient-swatch/index.html"
    },
    {
      "id": "qr-code",
      "title": "QR Code",
      "attachmentType": "plugin.preview.qr",
      "height": 240,
      "uiEntry": "renderers/qr-code/index.html"
    }
  ],
  "actions": []
}
