{
  "schemaVersion": 2,
  "plugin": {
    "id": "plugin.color",
    "title": "Color Inspector",
    "version": "0.1.0"
  },
  "install": {
    "runtime": "node",
    "entry": "scripts/install.mjs"
  },
  "runtime": {
    "nodeEntry": "dist/plugin.cjs",
    "uiRoot": "dist/ui"
  },
  "permissions": ["setAttachment"],
  "detectors": [
    {
      "id": "color-detector",
      "title": "Color Detector",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.color.swatch"]
    }
  ],
  "attachmentRenderers": [
    {
      "id": "color-swatch",
      "title": "Color Swatch",
      "attachmentType": "plugin.color.swatch",
      "height": 260,
      "uiEntry": "renderers/color-swatch/index.html"
    }
  ],
  "actions": [
    {
      "id": "color-copy",
      "title": "Copy Color Formats",
      "supportedItemTypes": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["color", "hex", "rgb"]
    }
  ]
}
