{
  "schemaVersion": 2,
  "plugin": {
    "id": "plugin.radix",
    "title": "Number Base",
    "version": "0.1.0"
  },
  "install": {
    "runtime": "node",
    "entry": "scripts/install.mjs"
  },
  "runtime": {
    "nodeEntry": "dist/plugin.cjs",
    "uiRoot": "dist/ui"
  },
  "permissions": ["setAttachment"],
  "detectors": [
    {
      "id": "radix-detector",
      "title": "进制识别",
      "supportedInputKinds": ["text"],
      "attachmentTypes": ["plugin.radix.number"]
    }
  ],
  "attachmentRenderers": [
    {
      "id": "radix-renderer",
      "title": "进制转换",
      "attachmentType": "plugin.radix.number",
      "height": { "min": 120, "max": 300 },
      "uiEntry": "renderers/radix-renderer/index.html"
    }
  ],
  "actions": [
    {
      "id": "radix-copy",
      "title": "复制各进制",
      "supportedItemTypes": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["radix", "hex", "binary", "octal", "decimal", "进制", "转换"]
    }
  ]
}
