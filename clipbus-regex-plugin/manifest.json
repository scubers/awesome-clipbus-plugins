    {
      "id": "regex-tool",
      "title": "Regex Tester",
      "supportedItemTypes": ["text"],
      "lifecycle": "draft",
      "uiEntry": "actions/regex-tool/index.html",
      "keywords": ["regex", "regexp", "正则", "匹配", "pattern"]
    }
  ]
}
