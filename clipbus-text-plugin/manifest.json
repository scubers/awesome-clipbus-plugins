{
  "schemaVersion": 3,
  "plugin": {
    "id": "plugin.text",
    "title": "Text Tools",
    "version": "0.1.0"
  },
  "install": {
    "runtime": "node",
    "entry": "scripts/install.mjs"
  },
  "runtime": {
    "nodeEntry": "dist/plugin.cjs",
    "uiRoot": "dist/ui"
  },
  "permissions": [],
  "detectors": [],
  "attachmentRenderers": [],
  "actions": [
    {
      "id": "text-sort",
      "title": "Sort Lines",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["sort", "order", "lines"]
    },
    {
      "id": "text-dedup",
      "title": "Remove Duplicate Lines",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["dedup", "unique", "duplicates"]
    },
    {
      "id": "text-trim",
      "title": "Tidy Whitespace",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["trim", "whitespace", "spaces"]
    },
    {
      "id": "text-strip-ansi",
      "title": "Strip ANSI Codes",
      "supportedInputKinds": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["ansi", "escape", "terminal", "color", "strip"]
    }
  ]
}
